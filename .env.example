# Public URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://bvpn:bvpn_password@localhost:5432/bvpn?schema=public
REDIS_URL=redis://localhost:6379

# Backend
BACKEND_PORT=4000
JWT_SECRET=change_me_to_a_long_random_secret
ADMIN_EMAIL=admin@bvpn.com
ADMIN_PASSWORD=ChangeMe123!
ENABLE_DEV_PAYMENTS=true

# Agent connection from backend
AGENT_URL=http://localhost:4100
AGENT_TOKEN=change_me_agent_token

# WireGuard agent
AGENT_PORT=4100
WG_INTERFACE=wg0
WG_SERVER_PUBLIC_KEY=replace_with_real_server_public_key
WG_SERVER_ENDPOINT=vpn.example.com:51820
WG_DNS=1.1.1.1
WG_ADDRESS_CIDR=10.8.0.0/24
WG_DRY_RUN=true

# Stripe, optional for MVP
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Crypto payment gateway, optional for MVP
CRYPTO_PROVIDER=nowpayments
CRYPTO_API_KEY=
CRYPTO_IPN_SECRET=
